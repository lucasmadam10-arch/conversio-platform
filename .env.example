# ===========================================
# Conversio Platform — Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ---- General ----
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
DASHBOARD_URL=http://localhost:5173
WIDGET_URL=http://localhost:5174

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/conversio_dev
DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5432/conversio_test

# ---- Redis ----
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ---- Auth / JWT ----
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
BCRYPT_ROUNDS=12

# ---- WebSocket ----
WS_PORT=3001
WS_HEARTBEAT_INTERVAL=30000

# ---- S3 / File Storage ----
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=conversio-uploads
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# ---- AI / LLM ----
ANTHROPIC_API_KEY=sk-ant-xxxxx
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=4096
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=sk-xxxxx

# ---- Vector Store (pgvector) ----
# Uses the same PostgreSQL database with pgvector extension
VECTOR_DIMENSIONS=1536

# ---- OpenSearch ----
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=admin

# ---- ClickHouse (Analytics) ----
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DATABASE=conversio_analytics

# ---- Email (SMTP for ticket ingress/notifications) ----
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=support@conversio.local

# ---- Social Channels (fill when needed) ----
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_VERIFY_TOKEN=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
WHATSAPP_BUSINESS_ID=
WHATSAPP_API_TOKEN=

# ---- Integrations ----
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
WEBHOOK_SIGNING_SECRET=change-me

# ---- Observability ----
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
LOG_LEVEL=debug

# ---- Encryption (for storing integration secrets) ----
ENCRYPTION_KEY=change-me-to-a-random-32-byte-hex-string
