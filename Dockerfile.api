FROM node:20-alpine
RUN corepack enable && corepack prepare pnpm@latest --activate
WORKDIR /app
COPY . .
RUN pnpm install --frozen-lockfile
RUN pnpm --filter @conversio/shared build
RUN pnpm --filter @conversio/db build
RUN pnpm --filter @conversio/api build
EXPOSE 4000
CMD ["node", "packages/api/dist/index.js"]
