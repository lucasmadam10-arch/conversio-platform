FROM node:20-alpine
RUN corepack enable && corepack prepare pnpm@latest --activate
WORKDIR /app
COPY . .
# Remove stale Windows build cache
RUN find . -name "*.tsbuildinfo" -delete && find . -name "*.dll.node" -delete
RUN pnpm install --frozen-lockfile
# tsc -b in api handles project references (shared, db) automatically
RUN pnpm --filter @conversio/api build
EXPOSE 4000
CMD ["node", "packages/api/dist/index.js"]
