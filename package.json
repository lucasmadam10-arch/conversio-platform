{
  "name": "conversio-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-product customer service SaaS platform",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:unit": "turbo test:unit",
    "test:integration": "turbo test:integration",
    "db:generate": "pnpm --filter @conversio/db prisma generate",
    "db:migrate": "pnpm --filter @conversio/db prisma migrate dev",
    "db:push": "pnpm --filter @conversio/db prisma db push",
    "db:seed": "pnpm --filter @conversio/db prisma db seed",
    "db:studio": "pnpm --filter @conversio/db prisma studio",
    "clean": "turbo clean && rm -rf node_modules",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "prettier": "^3.3.0",
    "turbo": "^2.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
