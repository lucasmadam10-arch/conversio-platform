{
  "name": "@conversio/db",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc && node -e \"require('fs').cpSync('src/generated', 'dist/generated', {recursive:true})\"",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "generate": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "seed": "tsx src/seed.ts",
    "studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.18.0",
    "bcryptjs": "^2.4.3"
  },
  "prisma": {
    "seed": "tsx src/seed.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.0",
    "prisma": "^5.18.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
