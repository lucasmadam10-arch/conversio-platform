{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2019",
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "lib": ["ES2019", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "composite": true,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
